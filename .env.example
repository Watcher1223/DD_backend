# Living Worlds — Environment Variables
# Copy to .env and fill in your API keys:
#   cp .env.example .env

# ── Gemini (story + dice vision) ─────────────────────────────────────────────
# Get a free key: https://aistudio.google.com/app/apikey
# Sign in with Google → Create API key. Free tier has daily limits.
GEMINI_API_KEY=your_gemini_api_key_here

# ── Scene images (NanoBanana 2 + Google fallback) ──────────────────────────────
# Primary: NANOBANANA_API_KEY (hackathon key). Images use NanoBanana 2.
# Fallback: Google Vertex Imagen uses the same GOOGLE_CLOUD_PROJECT below (enable Vertex AI API).
# If neither is set, placeholder (pollinations.ai) is used.
NANOBANANA_API_KEY=your_nanobanana_api_key_here

# ── Google Cloud (Imagen fallback + Lyria 2) ───────────────────────────────────
# Same project for: (1) scene image fallback when NanoBanana fails/unset, (2) Lyria music.
# Enable Vertex AI API in the project. Auth: gcloud auth application-default login
# or GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# VERTEX_AI_LOCATION=us-central1
# IMAGEN_MODEL=imagen-3.0-fast-generate-001

PORT=4300

# SQLite database file (default: ./data/living-worlds.db)
DB_PATH=./data/living-worlds.db
