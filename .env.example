# Living Worlds — Environment Variables
# Copy to .env and fill in your API keys:
#   cp .env.example .env

# ── Gemini (story + dice vision + Lyria RealTime) ─────────────────────────────
# Get a free key: https://aistudio.google.com/app/apikey
# Same key is used for: story/dice (generateContent), bedtime story (generateBedtimeStoryBeat), and Lyria RealTime (BidiGenerateMusic).
# Sign in with Google → Create API key. Free tier has daily limits.
GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-2.5-flash
# LYRIA_REALTIME_MODEL=models/lyria-realtime-exp

# ── Scene images (NanoBanana 2 or Vertex Imagen; no placeholder) ─────────────
# One of: NANOBANANA_API_KEY or GOOGLE_CLOUD_PROJECT (Vertex Imagen). Both require billing where applicable.
NANOBANANA_API_KEY=your_nanobanana_api_key_here

# ── Google Cloud (Imagen + Lyria 2; required for music, optional for images) ───
# GOOGLE_CLOUD_PROJECT required for Lyria music. Same project for Vertex Imagen (images when NanoBanana not used).
# Enable Vertex AI API + billing. Auth: gcloud auth application-default login
# or GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# Optional: force one Lyria prompt for all moods (if recitation blocks persist). Example: LYRIA_PROMPT_OVERRIDE="Instrumental only. No lyrics."
# VERTEX_AI_LOCATION=us-central1
# IMAGEN_MODEL=imagen-3.0-fast-generate-001

PORT=4300

# Optional: public base URL for QR code and WebSocket. When set:
# - POST /api/camera/pair returns phoneUrl with this host (so QR works when scanned on phone).
# - GET / returns websocket: wss://your-host (so frontend can connect to the right WS URL).
# Local dev (phone on same WiFi): http://YOUR_LAN_IP:4300
# Production: https://ddbackend-production.up.railway.app (or your deployed URL)
# PUBLIC_BASE_URL=https://ddbackend-production.up.railway.app

# SQLite database file (default: ./data/living-worlds.db)
DB_PATH=./data/living-worlds.db

# ── Chroma (optional semantic memory for character/scene consistency) ─────────
# Option A — Chroma Cloud: set CHROMADB_API_KEY (from https://cloud.trychroma.com).
#   No local server or CLI needed; the backend uses the Chroma JS client with this key.
# Option B — Self-hosted: run a Chroma server (e.g. npx chroma run --path ./data/chroma
#   or Docker: docker run -p 8000:8000 chromadb/chroma) and use CHROMA_HOST/PORT below.
# CHROMADB_API_KEY=your_chroma_cloud_api_key   # Chroma Cloud; when set, host/port are ignored
# CHROMA_API_KEY=                              # alternative env name (same as CHROMADB_API_KEY)
# CHROMA_TENANT=                               # optional for Chroma Cloud
# CHROMA_DATABASE=                             # optional for Chroma Cloud
# CHROMA_ENABLED=false            # set to "false" to disable even if server is reachable
# CHROMA_HOST=localhost            # Chroma server host (default: localhost; ignored if CHROMADB_API_KEY set)
# CHROMA_PORT=8007                 # Chroma server port (default: 8000)
# CHROMA_SSL=false                 # use HTTPS (default: false)
# CHROMA_COLLECTION_PREFIX=lw     # prefix for collection names (lw_appearance, lw_story)
# CHROMA_TOP_K=5                  # default number of results for similarity queries
# CHROMA_REID_DISTANCE_THRESHOLD=0.5   # max Chroma distance to re-identify a returning stage character (judge/hero)

# ── LiveKit (real-time video pipeline: WHIP ingest, WHEP egress) ─────────────
# Required for bedtime story video: stage camera → LiveKit room → vision/V2V → display.
# Get keys from https://cloud.livekit.io or self-hosted LiveKit Server.
# LIVEKIT_URL=wss://your-project.livekit.cloud
# LIVEKIT_API_KEY=your_api_key
# LIVEKIT_API_SECRET=your_api_secret
# LIVEKIT_ROOM_PREFIX=story         # room name becomes {prefix}-{campaignId} (e.g. story-abc123)
