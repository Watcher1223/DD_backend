# Living Worlds — Environment Variables
# Copy to .env and fill in your API keys:
#   cp .env.example .env

# ── Gemini (story + dice vision + Lyria RealTime) ─────────────────────────────
# Get a free key: https://aistudio.google.com/app/apikey
# Same key is used for: story/dice (generateContent), bedtime story (generateBedtimeStoryBeat), and Lyria RealTime (BidiGenerateMusic).
# Sign in with Google → Create API key. Free tier has daily limits.
GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-2.5-flash
# LYRIA_REALTIME_MODEL=models/lyria-realtime-exp

# ── Scene images (NanoBanana 2 or Vertex Imagen; no placeholder) ─────────────
# One of: NANOBANANA_API_KEY or GOOGLE_CLOUD_PROJECT (Vertex Imagen). Both require billing where applicable.
NANOBANANA_API_KEY=your_nanobanana_api_key_here

# ── Google Cloud (Imagen + Lyria 2; required for music, optional for images) ───
# GOOGLE_CLOUD_PROJECT required for Lyria music. Same project for Vertex Imagen (images when NanoBanana not used).
# Enable Vertex AI API + billing. Auth: gcloud auth application-default login
# or GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# Optional: force one Lyria prompt for all moods (if recitation blocks persist). Example: LYRIA_PROMPT_OVERRIDE="Instrumental only. No lyrics."
# VERTEX_AI_LOCATION=us-central1
# IMAGEN_MODEL=imagen-3.0-fast-generate-001

PORT=4300

# SQLite database file (default: ./data/living-worlds.db)
DB_PATH=./data/living-worlds.db

# ── Chroma (optional semantic memory for character/scene consistency) ─────────
# Requires a running Chroma server: npx chroma run --path ./data/chroma
# Or Docker: docker run -p 8000:8000 chromadb/chroma
# CHROMA_ENABLED=false            # set to "false" to disable even if server is reachable
# CHROMA_HOST=localhost            # Chroma server host (default: localhost)
CHROMA_PORT=8007                 # Chroma server port (default: 8000)
# CHROMA_SSL=false                 # use HTTPS (default: false)
# CHROMA_COLLECTION_PREFIX=lw     # prefix for collection names (lw_appearance, lw_story)
# CHROMA_TOP_K=5                  # default number of results for similarity queries
